{
  "name": "@vorionsys/rainbow",
  "version": "0.3.0",
  "description": "RAINBOW - Recorded Analytics Involving Non-Binary Orchestration Window",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./collector": {
      "types": "./dist/collector/index.d.ts",
      "import": "./dist/collector/index.js"
    },
    "./window": {
      "types": "./dist/window/index.d.ts",
      "import": "./dist/window/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration/index.d.ts",
      "import": "./dist/orchestration/index.js"
    },
    "./insight": {
      "types": "./dist/insight/index.d.ts",
      "import": "./dist/insight/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@vorionsys/basis-spec": "^1.2.0",
    "@vorionsys/contracts": "^1.1.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.18"
  },
  "author": "Vorion LLC <team@vorion.org>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voriongit/rainbow.git"
  },
  "bugs": {
    "url": "https://github.com/voriongit/rainbow/issues"
  },
  "homepage": "https://vorion.org",
  "keywords": [
    "ai",
    "governance",
    "trust",
    "analytics",
    "rainbow",
    "vorion",
    "nist",
    "compliance",
    "observability"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "drizzle-orm": "^0.45.2"
  }
}
